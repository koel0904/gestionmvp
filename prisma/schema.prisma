// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


model Local {
  id      String @id @default(uuid())
  name    String
  address String?
  phone   String?
  email   String?

  ownerId String
  owner   Owner @relation(fields: [ownerId], references: [id])

  users       User[]
  proveedores Proveedores[]
  inventario  Inventario[]
  ventas      Ventas[]
  clientes    Clientes[]
}

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  phone       String?
  password    String   @db.VarChar(255)
  role        String   @default("user")
  permissions Json     @default("[]")
  twoFactorCode  String? @db.VarChar(255)
  twoFactorCodeExpiry DateTime?

  localId  String?
  local    Local? @relation(fields: [localId], references: [id])

  ownerId  String
  owner    Owner @relation(fields: [ownerId], references: [id])
}

model Owner {
  id      String  @id @default(uuid())
  name    String
  email   String  @unique
  phone   String?
  password    String   @db.VarChar(255)
  role        String   @default("owner")
  permissions Json     @default("[]")
  twoFactorCode  String? @db.VarChar(255)
  twoFactorCodeExpiry DateTime?

  users  User[]
  locales Local[]
}

model Proveedores {
  id      String  @id @default(uuid())
  name    String
  email   String?
  phone   String?
  
  local   Local   @relation(fields: [localId], references: [id])
  localId String

  inventario Inventario[]
}

model Inventario {
  id            String  @id @default(uuid())
  name          String
  precio_compra Float
  precio_venta  Float
  stock         Int
  
  proveedor   Proveedores @relation(fields: [proveedorId], references: [id])
  proveedorId String
  
  local   Local   @relation(fields: [localId], references: [id])
  localId String

  ventas Ventas[]
}

model Clientes {
  id    String  @id @default(uuid())
  name  String
  email String  @unique
  phone String?

  local   Local   @relation(fields: [localId], references: [id])
  localId String

  ventas Ventas[]
}

model Ventas {
  id           String   @id @default(uuid())
  cantidad     Int
  precio_venta Float
  total        Float
  fecha        DateTime @default(now())
  
  cliente   Clientes @relation(fields: [clienteId], references: [id])
  clienteId String
  
  inventario   Inventario @relation(fields: [inventarioId], references: [id])
  inventarioId String

  local   Local   @relation(fields: [localId], references: [id])
  localId String
}

